# ══════════════════════════════════════════════════════════════
# ZOLTAR — Variables de Entorno
# Copia este archivo como .env.local para desarrollo local
# Configura cada una también en Vercel → Settings → Environment Variables
# ══════════════════════════════════════════════════════════════

# ── Gemini (ya configurada) ────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Supabase ───────────────────────────────────────────────
# En: https://supabase.com → tu proyecto → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Key (SOLO para funciones serverless — NO exponer en frontend)
# En: Supabase → Settings → API → service_role key
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Stripe ─────────────────────────────────────────────────
# En: https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_xxxx          # usar sk_test_xxx en desarrollo
STRIPE_WEBHOOK_SECRET=whsec_xxxx        # obtener al crear el webhook en Stripe

# ── App URL (para Stripe redirect y imágenes) ──────────────
APP_URL=https://zoltar-two.vercel.app   # cambiar si usas dominio propio
